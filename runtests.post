#!/usr/bin/bash

# Provided scanner tests given post assignment period are done here.
# depends on runvc to function
for test in $(find "provided.tests/Scanner/tests/" -type f); do
    [ -d "provided.tests/Scanner/output/" ] || mkdir "provided.tests/Scanner/output/"
    testno=$(basename "$test" | sed 's/test//')
    "./runvc" "provided.tests/Scanner/tests/test$testno" > "provided.tests/Scanner/output/result$testno"
    diff -u "provided.tests/Scanner/expected/result$testno" "provided.tests/Scanner/output/result$testno"
done
